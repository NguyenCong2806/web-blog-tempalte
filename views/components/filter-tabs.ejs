<%
    // filter-tabs component
    // expects: {tabs} where each tab: {label, value, active}
%>
<% if (tabs && tabs.length) { %>
    <div class="flex flex-wrap gap-2 justify-center mb-6">
        <% tabs.forEach(function(tab) { %>
            <button type="button" data-value="<%= tab.value %>"
                class="px-4 py-2 rounded-full text-sm font-semibold transition <%= tab.active ? 'bg-teal-600 text-white' : 'bg-gray-100 text-gray-700 hover:bg-teal-50 hover:text-teal-600' %>">
                <%= tab.label %>
            </button>
        <% }); %>
    </div>
<% } %>