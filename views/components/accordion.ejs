<div data-aos="fade-up" data-aos-duration="800" class="max-w-4xl mx-auto">
    <div class="space-y-4">
      <% accordions.forEach(function(item, idx) { %>

        <% var isOpen=item.open || idx===0; %>

          <details class="group bg-slate-50 rounded-lg overflow-hidden transition-all duration-300" <%=isOpen ? 'open'
            : '' %>>
            <summary
              class="flex items-center justify-between cursor-pointer p-5 list-none select-none hover:bg-slate-100 transition-colors [&::-webkit-details-marker]:hidden">
              <h3 class="text-base font-bold text-slate-900">
                <%= item.title %>
              </h3>
              <div
                class="shrink-0 transition-transform duration-300 group-open:rotate-180 text-slate-500 w-4 h-4 flex items-center justify-center">
                <i class="fa-solid fa-chevron-down text-xs"></i>
              </div>
            </summary>

            <div class="px-5 pb-5 pt-0 text-slate-600 text-sm leading-relaxed">
              <div class="prose prose-sm max-w-none prose-ul:list-disc prose-ul:pl-4 prose-li:mb-1">
                <%- item.detail %>
              </div>
            </div>
          </details>
          <% }); %>
    </div>
</div>