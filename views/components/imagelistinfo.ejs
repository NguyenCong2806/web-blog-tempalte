<% if (typeof imageListInfos !== 'undefined' && imageListInfos.length > 0) { %>
  <style>
    .imagelist-card.active .imagelist-gradient,
    .imagelist-card.active .imagelist-overlay {
      opacity: 1 !important;
    }
    .imagelist-card.active .imagelist-img {
      transform: scale(1.1) !important;
    }
  </style>
  <div class="imagelist-autoplay flex items-center justify-start gap-4 overflow-x-auto overflow-y-hidden py-8 px-4 snap-x snap-mandatory touch-pan-x md:px-6 xl:justify-center" data-autoplay-duration="300000" data-autoplay-interval="7000">
    <% imageListInfos.forEach(function(item) { %>
      <% const imageAlt = item.text ? item.text.replace(/<[^>]*>/g, '') : ''; %>
      <% if (item.link) { %>
        <a href="<%= item.link %>" target="_blank" class="imagelist-card group relative overflow-hidden rounded-[1.75rem] border border-white/10 bg-slate-950/10 shadow-lg transition-all duration-500 ease-out snap-start flex-shrink-0 w-16 min-w-[4rem] h-60 sm:w-20 sm:min-w-[5rem] sm:h-72 md:w-24 md:min-w-[6rem] md:h-80 lg:h-96 lg:w-24 lg:min-w-[6rem] lg:hover:w-[34rem] hover:shadow-[0_35px_60px_-35px_rgba(0,0,0,0.75)]">
      <% } else { %>
        <div class="imagelist-card group relative overflow-hidden rounded-[1.75rem] border border-white/10 bg-slate-950/10 shadow-lg transition-all duration-500 ease-out snap-start flex-shrink-0 w-16 min-w-[4rem] h-60 sm:w-20 sm:min-w-[5rem] sm:h-72 md:w-24 md:min-w-[6rem] md:h-80 lg:h-96 lg:w-24 lg:min-w-[6rem] lg:hover:w-[34rem] hover:shadow-[0_35px_60px_-35px_rgba(0,0,0,0.75)]">
      <% } %>
          <img src="<%= item.img || '/images/logos/placeholder.png' %>" alt="<%= imageAlt %>"
            class="imagelist-img absolute inset-0 h-full w-full object-cover transition-transform duration-500 ease-out group-hover:scale-110"
            loading="lazy">
          <div class="imagelist-gradient absolute inset-0 bg-gradient-to-r from-slate-950/95 via-slate-950/40 to-transparent opacity-0 transition-opacity duration-500 ease-out group-hover:opacity-100"></div>
          <div class="imagelist-overlay absolute inset-0 flex items-end p-4 sm:p-6 text-white opacity-0 transition-opacity duration-500 ease-out group-hover:opacity-100">
            <div class="max-w-full sm:max-w-[55%]">
              <span class="block text-xs uppercase tracking-[0.24em] text-slate-400">Partner spotlight</span>
              <div class="mt-3 text-base font-semibold leading-tight sm:text-xl"><%- item.text %></div>
            </div>
          </div>
      <% if (item.link) { %>
        </a>
      <% } else { %>
        </div>
      <% } %>
    <% }); %>
  </div>
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      var container = document.querySelector('.imagelist-autoplay');
      if (!container) return;

      var cards = Array.prototype.slice.call(container.querySelectorAll('.imagelist-card'));
      if (!cards.length) return;

      var activeIndex = -1;
      var autoplayInterval = parseInt(container.dataset.autoplayInterval, 10) || 7000;
      var autoplayDuration = parseInt(container.dataset.autoplayDuration, 10) || 300000;
      var autoplayTimer = null;
      var stopTimer = null;

      function clearActive() {
        if (activeIndex >= 0 && cards[activeIndex]) {
          cards[activeIndex].classList.remove('active', '!w-[calc(100vw-2rem)]', 'lg:!w-[34rem]', '!shadow-[0_35px_60px_-35px_rgba(0,0,0,0.75)]');
        }
        activeIndex = -1;
      }

      function setActiveCard(index) {
        if (activeIndex === index) return;
        clearActive();
        activeIndex = index;
        if (activeIndex >= 0 && cards[activeIndex]) {
          cards[activeIndex].classList.add('active', '!w-[calc(100vw-2rem)]', 'lg:!w-[34rem]', '!shadow-[0_35px_60px_-35px_rgba(0,0,0,0.75)]');
        }
      }

      function chooseRandomCard() {
        var nextIndex = Math.floor(Math.random() * cards.length);
        setActiveCard(nextIndex);
      }

      function startAutoplay() {
        if (autoplayTimer) return;
        chooseRandomCard();
        autoplayTimer = window.setInterval(chooseRandomCard, autoplayInterval);
        stopTimer = window.setTimeout(function () {
          if (autoplayTimer) {
            window.clearInterval(autoplayTimer);
            autoplayTimer = null;
          }
        }, autoplayDuration);
      }

      cards.forEach(function (card, index) {
        card.addEventListener('mouseenter', function () {
          setActiveCard(index);
        });
        card.addEventListener('mouseleave', function () {
          if (autoplayTimer) return;
          clearActive();
        });
      });

      startAutoplay();
    });
  </script>
<% } else { %>
  <p class="col-span-full text-center text-gray-400 text-sm">Đang cập nhật danh sách đối tác...</p>
<% } %>