<div class="container mx-auto px-4 py-12">

  <% if (Array.isArray(courses) && courses.length> 0) { %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">

      <% courses.forEach(function(item, index) { %>

        <div class="group w-full max-w-sm aspect-[4/5] mx-auto [perspective:1000px]">
          <div class="relative w-full h-full transition-transform duration-700 
              [transform-style:preserve-3d] 
              group-hover:[transform:rotateY(180deg)]">

            <!-- FRONT -->
            <div class="absolute inset-0 [backface-visibility:hidden]">
              <img src="<%= item.img || '/images/default-placeholder.jpg' %>" alt="<%= item.title %>"
                class="w-full h-full object-cover rounded-2xl shadow-xl" />

              <!-- overlay -->
              <div class="absolute inset-0 bg-black/40 flex items-end p-4 rounded-2xl">
                <h3 class="text-white text-lg font-semibold">
                  <%= item.title %>
                </h3>
              </div>
            </div>

            <!-- BACK -->
            <div class="absolute inset-0 [transform:rotateY(180deg)] 
                [backface-visibility:hidden] 
                bg-white rounded-2xl shadow-2xl p-5 flex flex-col justify-center">

              <h2 class="text-xl font-bold mb-2">
                <%= item.title %>
              </h2>

              <div
                class="text-gray-600 text-md text-justify leading-relaxed line-clamp-4 group-hover:text-gray-900 transition-colors duration-300">
                <%- item.detail.replace(/\n/g, '<br>' ) %>
              </div>

              <button class="mt-4 px-4 py-2 bg-black text-white rounded-lg 
                     hover:bg-gray-800 transition">
                Xem ngay
              </button>
            </div>

          </div>
        </div>
        <% }); %>
    </div>
    <% } else { %>
      <%- include('./empty-state.ejs') %>
        <% } %>
</div>