<div class="relative" data-aos="fade-up-left">
    <div id="box-container" class="flex flex-col md:flex-row justify-start items-start gap-6 mb-8 group p-4 rounded-lg border border-slate-100 transition-colors duration-300 hover:bg-gray-100 w-full transition-opacity duration-700 ease-in-out opacity-100">
        <div class="inline-block overflow-hidden rounded-lg w-full md:w-1/3 flex-shrink-0 h-48 md:h-64">
            <img id="display-image" src="/images/default-placeholder.jpg" alt="anh"
                class="w-full h-full object-cover transform transition-transform duration-500 group-hover:scale-90"
                loading="lazy">
        </div>
        <div class="inline-block w-full">
            <h2 id="display-title" class="text-2xl md:text-3xl font-bold mb-4 text-slate-700 group-hover:text-slate-900 transition-colors duration-300">
                Tiêu đề mặc định
            </h2>
            <div id="note-container" class="text-gray-600 text-sm md:text-base font-light leading-relaxed line-clamp-4 group-hover:text-gray-900 transition-colors duration-300">
                <p id="display-note" class="text-justify">Lorem ipsum dolor sit amet...</p>
            </div>
        </div>
    </div>
</div>

<script>
    // 1. Chuyển dữ liệu từ Server-side sang Client-side JS
    // Cần đảm bảo dữ liệu được JSON.stringify để JS hiểu được
    const items = JSON.parse('<%- JSON.stringify(boximagetexts || []) %>');

    let currentIndex = 0;

    // Hàm cập nhật giao diện với hiệu ứng mượt mà
    function updateUI(index) {
        if (!items || items.length === 0) return;
        const container = document.getElementById('box-container');
        const data = items[index];

        // bắt đầu fade out
        if (container) {
            container.style.opacity = '0';
        }

        setTimeout(() => {
            // fetch DOM elements by their correct IDs
            const elTitle   = document.getElementById('display-title');
            const elNote    = document.getElementById('display-note');
            const elNoteBox = document.getElementById('note-container');
            const elImage   = document.getElementById('display-image');

            // cập nhật các trường đơn giản
            if (elTitle) elTitle.innerText = data.heading || "Tiêu đề mặc định";

            if (elNoteBox && elNote) {
                if (data.note) {
                    elNoteBox.style.display = "block";
                    // allow HTML formatting or line breaks in the note text
                    elNote.innerHTML = data.note.replace(/\n/g, '<br>');
                } else {
                    elNoteBox.style.display = "none";
                }
            }

            if (elImage && data.image) {
                elImage.src = data.image;
            }

            // fade back in
            if (container) {
                container.style.opacity = '1';
            }
        }, 300); // khoảng thời gian fade (ms)
    }

    function changeItem(direction) {
        // nothing to do if there are zero or one items
        if (items.length <= 1) return;

        if (direction === 'next') {
            currentIndex = (currentIndex + 1) % items.length;
        } else {
            currentIndex = (currentIndex - 1 + items.length) % items.length;
        }

        updateUI(currentIndex);
    }

    // initialize and start automatic rotation
    document.addEventListener('DOMContentLoaded', () => {
        updateUI(0);
        // rotate every 3 seconds (3000 ms) – will wrap around the items
        setInterval(() => changeItem('next'), 10000);
    });
</script>