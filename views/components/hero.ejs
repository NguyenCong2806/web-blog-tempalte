<%
    // Hero component
    // expects: { title, subtitle, backgroundImage, overlayGradient }
%>
<section class="relative overflow-hidden">
    <% if (backgroundImage) { %>
        <div class="absolute inset-0 bg-cover bg-center" style="background-image:url('<%= backgroundImage %>')"></div>
        <div class="absolute inset-0 <%= overlayGradient || 'bg-gradient-to-b from-black/50 to-black/25' %>"></div>
    <% } else { %>
        <div class="absolute inset-0 bg-gradient-to-r from-teal-500 to-blue-500"></div>
    <% } %>
    <div class="relative container mx-auto px-4 py-24 text-center text-white">
        <% if (title) { %>
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold mb-4"><%= title %></h1>
        <% } %>
        <% if (subtitle) { %>
            <p class="text-lg md:text-xl max-w-2xl mx-auto"><%= subtitle %></p>
        <% } %>
    </div>
</section>